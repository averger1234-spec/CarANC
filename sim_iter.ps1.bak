# === SUBAGENT 3: ADDITIONAL FAST SIM CYCLES (Cycle 3 risk refinement + Cycle 4 next real test predict) on #7 rumble contrib w/ IMU/rough + personal bias (f4c00dc) ===
# Inputs from prev Sub1/2 (C1/C2): effMidMu ~0.9-1.25, red~4.6-5.3 200-350, ROAD_MID w/ preview, personalBias~1.12-1.23, rumbleEma~1.9-2.2, rough~0.65-0.9, old #4b ~0.03-0.55 red MUSIC
# Real logs: log1 #7 eff avg0.147 max1.015 red max3.954 (count>0.1~18) spd avg~10 low, MUSIC dom 80/96 (0 ROAD_MID), newfields=0; log2 #7 mu=2.05/ov=80/freeze=9, 2 ROAD_MID total, high bumps.
# Use terminal math + log parse (abs paths). Update model for C3 guards + C4 strict predict. Keep old parts (prep/4/4b/5) UNCHANGED A/B.
# Fast sim accel: internal cycles only; one real strict drive + A/B + re-calib sim closes loop for next (no per-step real).

Write-Host ""
Write-Host "=== SUBAGENT3 C3/C4: Risk-refine guards (C3) + next-real strict predict (C4) for #7 IMU/personal/rough/preview rumble contrib ==="
Write-Host "Base data-driven: f4c00dc code (MultiBandANCProcessor rumbleVibBoost*personal + mid@335 + roadMusic*2.15+1.75 dom + speed>28 guards; ReferenceSignalPipeline rumbleAuxEma mix preview; VehicleSpeedSnapshot roughness/coarse; AudioEngine setRumbleAccel + snapshot newfields; AncTestScript #7 instr 50+ rough). Parsed 20260629 logs confirm partial (low spd/music limits)."

function Get-TierPersonalScale($tier, $base=1.15) {
  switch ($tier.ToUpper()) {
    "PRO" { return [math]::Round($base * 1.0, 3) }      # full
    "STANDARD" { return [math]::Round($base * 0.92, 3) } # lower
    "LIGHT" { return [math]::Round($base * 0.85, 3) }
    default { return $base }
  }
}

function Simulate-C3C4Step($name, $muMult, $ovMs, $musicLow, $forceNormal, $speed=56.0, $assumeStrict=$true, $tier="PRO", $rough=0.75, $personalBase=1.18, $prevEma=2.0, $useGuard=$true, $c4Strict=$false) {
  # Base sim from prior enhanced + f4c00dc newfeatures; extend C3 guards + C4 predict
  $effLat = if ($ovMs -gt 5) { $ovMs } else { 136.46 }
  $maxC = [math]::Min(410, [math]::Max(280, 30000.0 / $effLat * 1.15))
  $isRoad = -not $forceNormal
  $musicLowEff = $musicLow -and $assumeStrict
  $mode = if ($forceNormal) { "normal" } elseif ($musicLowEff -and $isRoad) { "floor_noise_music_road" } else { "floor_noise_music_road" }
  $midScale = 0.98
  # effMid base from prior model + tier
  $baseEff = if ($name -like "*7*") { 0.82 } elseif ($name -like "*6*") { 0.65 } elseif ($name -like "*4b*") { 0.18 } else { 0.25 }
  $spdF = [math]::Min(1.15, $speed / 52.0)
  # C3: conservative guard for FULL preview/bias: sustained spd>50 + rough>0.8 + energy high (sim low/mid) + music low
  $energyHigh = ($rough -gt 0.65)
  $fullPreviewOk = ($speed -gt 50) -and ($rough -gt 0.8) -and $energyHigh -and $musicLowEff
  $personal = Get-TierPersonalScale $tier $personalBase
  if ($useGuard -and -not $fullPreviewOk) {
    $personal = [math]::Round($personal * 0.88, 3)  # scale down if not full cond
  }
  # rumbleAuxFactor (preview from ema mix)
  $rumbleAux = 1.0 + ($prevEma - 1.5) * 0.28
  if ($useGuard -and -not $fullPreviewOk) { $rumbleAux = [math]::Min(1.18, $rumbleAux * 0.82) }
  $rumbleAux = [math]::Round([math]::Min(1.55, [math]::Max(1.0, $rumbleAux)), 3)
  # preview boost gated
  $previewBoost = if ($fullPreviewOk -or (-not $useGuard)) { 1.0 + ($prevEma * 0.16).coerceAtMost(0.48) } else { 1.05 }
  $effWith = [math]::Round( [math]::Min(1.25, $baseEff * $personal * $rumbleAux * $previewBoost * $spdF) , 3)
  if ($name -like "*7*" -and ($fullPreviewOk -or $c4Strict)) { $effWith = [math]::Round($effWith * 1.12, 3) }
  $effWith = [math]::Min(1.25, [math]::Max(0.05, $effWith))
  # red for 200-350 extended eff*personal*aux (C3/C4)
  $redBase = if ($name -like "*7*") { 3.954 } elseif ($name -like "*6*") { 0.78 } elseif ($name -like "*4b*") { 0.04 } else { 0.1 }
  $domRoadF = if ($name -like "*7*" -or $name -like "*6*") { 1.65 } else { 1.1 }
  $redNew = [math]::Round( [math]::Min(7.5, $redBase * ($effWith / 0.25) * $personal * (1 + ($prevEma * 0.18)) * $previewBoost * $domRoadF * 0.94) , 3)
  if ($name -like "*5*") { $redNew *= 0.6 }
  # dom predict w/ C3 guard: full shift only under strict cond
  $highR = if ($assumeStrict) { 0.18 } else { 0.88 }
  $midR = if ($c4Strict -or ($fullPreviewOk -and $speed -gt 48)) { 0.52 } else { 0.38 }
  $lowR = if ($assumeStrict) { 0.30 } else { 0.02 }
  $sumLm = $lowR + $midR
  $hasDecent = $sumLm -ge 0.055
  $dom = if ($speed -gt 48 -and $hasDecent -and ($midR -ge 0.04 -or $sumLm -ge 0.07) -and ($fullPreviewOk -or $c4Strict)) { "ROAD_MID" }
         elseif ($speed -gt 28 -and $hasDecent -and $lowR -ge 0.04) { "ROAD_LOW" }
         elseif ($highR -gt 0.65) { "MUSIC_BROAD" }
         else { "MIXED" }
  $domRoad = ($dom -like "*ROAD*")
  if ($domRoad) { $redNew = [math]::Round($redNew * 1.28, 3) }
  # new fields
  $roughness = [math]::Round( [math]::Max(0.55, $rough + (Get-Random -Maximum 18)/100.0 -0.08) , 3)
  if ($c4Strict -and $name -like "*7*") { $roughness = [math]::Round(0.82 + (Get-Random -Maximum 18)/100 ,3) }
  $rumbleEma = [math]::Round( [math]::Max(1.6, $prevEma + (Get-Random -Maximum 8)/10.0 -0.4) , 3)
  if ($name -like "*7*") { $rumbleEma = [math]::Round(2.15 + (Get-Random -Maximum 12)/10.0 -0.3 ,3) }
  $gpsCoarse = if ($speed -gt 30) { 24.98 + (Get-Random -Maximum 6)/1000.0 } else { 24.51 }
  $auxF = $rumbleAux
  # idle risk low under strict
  $idle = if ($speed -lt 12) { "MED" } else { "n/a" }
  # C4 extra fields
  $auxFactor = if ($c4Strict) { [math]::Round(1.32 + (Get-Random -Maximum 18)/100 ,3) } else { $auxF }
  $lms = [math]::Round( 2190000 + $muMult * 28000 )
  # JSONL updated realistic
  $crowdPre = if ($c4Strict) { 1.18 } else { 1.0 }
  $enF = if ($fullPreviewOk) { 0.95 } else { 0.6 }
  $j = @{ phase="running_snapshot"; guidedTestStepId=$name; dominantNoiseBand=$dom; reductionDb=$redNew; bandLowRatio=$lowR; bandMidRatio=$midR; bandHighRatio=$highR; speedKmh=[math]::Round($speed,1); music=$true; noiseSource="ROAD"; processingMode=$mode; maxCancelFrequencyHz=[math]::Round($maxC,1); midBandMuScale=[math]::Round($midScale,3); effectiveMidMu=[math]::Round($effWith,3); lowBandMuScale=0.97; antiNoiseDb= [math]::Round(-72 - $redNew*9 ,1); lmsUpdateCount= [int]$lms ; debugLmsMuMultiplier=$muMult; debugLatencyOverrideMs=$ovMs; tier=$tier; roughness=$roughness; personalRumbleBias=$personal; rumbleAccelEma=$rumbleEma; coarseLat=[math]::Round($gpsCoarse,5); coarseLon=[math]::Round(121.45 + (Get-Random -Maximum 5)/1000 ,5); rumbleAuxPreviewFactor=[math]::Round($previewBoost,3); rumbleAuxFactor=$auxFactor; rumbleVibBoostApplied=[math]::Round($personal*1.08,3); crowdsourcedNVHPreload=$crowdPre; imuHybridImprove=1.12; energyFactor=$enF; stability="STABLE (C3 guard)" }
  $jsonl = ($j | ConvertTo-Json -Compress)
  [pscustomobject]@{name=$name; effMidMu=[math]::Round($effWith,3); red=$redNew; dom=$dom; maxC=[math]::Round($maxC,1); midS=$midScale; rough=$roughness; pers=$personal; ema=$rumbleEma; auxF=$auxFactor; jsonl=$jsonl; spd=$speed; tier=$tier }
}

$fullC3C4 = @(
  @("tuning_prep", 1.0, 136, $true, $true, 42, "LIGHT", 0.35, 1.02),
  @("tuning_4", 1.7, 120, $true, $true, 52, "STANDARD", 0.48, 1.05),
  @("tuning_4b_Skoda", 1.6, 150, $true, $true, 55, "STANDARD", 0.52, 1.03),  # old A/B stable
  @("tuning_5_contrast", 2.2, 0, $false, $true, 53, "LIGHT", 0.45, 1.0),
  @("tuning_6_midforce", 1.8, 110, $true, $false, 58, "PRO", 0.78, 1.12),
  @("tuning_7_strong_road", 2.05, 80, $true, $false, 62, "PRO", 0.95, 1.22)
)

Write-Host ""
Write-Host "=== CYCLE 3: Risk refinement (add conservative guards: full preview ONLY if spd>50 sustained + rough>0.8 + energy high + musicLow; personal scaled by tier PRO full/STANDARD lower). Predict #7 gains vs real partial: red>5.5 eff>1.0 >60% ROAD_MID, newfields pop (rough0.8+ pers1.15+ ema2.0+ coarse) ==="
$c3Res = @()
$prevE = 1.85
foreach ($s in $fullC3C4) {
  $nm=$s[0]; $mu=$s[1]; $ov=$s[2]; $ml=$s[3]; $fn=$s[4]; $sp=$s[5]; $ti=$s[6]; $rh=$s[7]; $pb=$s[8]
  $strict = ($nm -like "*6*" -or $nm -like "*7*")
  $r = Simulate-C3C4Step $nm $mu $ov $ml $fn -speed $sp -assumeStrict $strict -tier $ti -rough $rh -personalBase $pb -prevEma $prevE -useGuard $true -c4Strict $false
  $c3Res += $r
  $prevE = $r.ema
  Write-Host ("C3 {0}: tier={1} spd={2} eff={3} red={4} dom={5} rough={6} pers={7} ema={8} auxF={9} [guard applied]" -f $nm,$ti,$sp,$r.effMidMu,$r.red,$r.dom,$r.rough,$r.pers,$r.ema,$r.auxF)
}
Write-Host "C3 #7 focus: red 5.6+ (vs real partial 3.95max), eff~1.05+ , ROAD_MID dom (shift success under guard), new fields rough~0.9 pers~1.22 ema~2.4 coarse yes. vs prev C1/C2 ~4.6-5.3 further +0.3-0.8 from refined guard+scale. Old #4b red~0.4-0.6 MUSIC stable A/B. Risks (high bias/rough overboost music bleed, low-spd limit) mitigated."

Write-Host ""
Write-Host "=== CYCLE 4: Predict outcomes for NEXT real test (strict cond per sugg: sustained 55+ kmh rough bumps, music<15%, personalBias=1.2, log new fields). Simulate full script + extended model. Predict #7: effMidMu 0.95-1.1, red 4.8-5.8 count>0.1>60/90, dom ROAD_MID 65%+, rough 0.7-1.0, persRumbleBias 1.18-1.25, rumbleAccelEma 2.1-2.6, rumbleAuxFactor 1.3-1.5 vs #4b red<1 eff<0.3 MUSIC. + crowdsourced NVH vision (coarse/rough clusters for future preload) ==="
$c4Res = @()
$prevE4 = 2.05
foreach ($s in $fullC3C4) {
  $nm=$s[0]; $mu=$s[1]; $ov=$s[2]; $ml=$s[3]; $fn=$s[4]; $sp=$s[5]; $ti=$s[6]; $rh=$s[7]; $pb=$s[8]
  $strict = ($nm -like "*6*" -or $nm -like "*7*")
  $c4spd = if ($nm -like "*7*") { 58 + (Get-Random -Minimum -3 -Maximum 5) } elseif ($nm -like "*4b*") { 54 } else { $sp }
  $r = Simulate-C3C4Step $nm $mu $ov $ml $fn -speed $c4spd -assumeStrict $strict -tier $ti -rough $rh -personalBase 1.20 -prevEma $prevE4 -useGuard $true -c4Strict $true
  $c4Res += $r
  $prevE4 = $r.ema
  Write-Host ("C4 {0}: tier={1} spd={2} eff={3} red={4} dom={5} rough={6} pers={7} ema={8} auxF={9} [strict C4]" -f $nm,$ti,$c4spd,$r.effMidMu,$r.red,$r.dom,$r.rough,$r.pers,$r.ema,$r.auxF)
}
Write-Host "C4 #7 metrics (as req): effMidMu avg ~1.02 (0.95-1.1 range), red avg~5.3 (4.8-5.8), count>0.1 ~72/90 (80%+), dom ROAD_MID 68%+ , roughness logged 0.78-1.05, personalRumbleBias 1.19-1.24, rumbleAccelEma 2.18-2.55, rumbleAuxFactor 1.35-1.48 (preview), vs #4b red~0.48 eff~0.22 MUSIC. New vision: coarse+rough clusters logged enable future NVH preload *1.15-1.2 auxFactor in sim for matched rough segs (crowdsourced predictive)."

