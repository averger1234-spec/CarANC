Write-Host "Loop2 (personal bias tweak + strict spd instr): better red/eff/dom from protocol."
Write-Host "Loop3 (crowdsourced preload from aggregated coarse/rough clusters of prior runs): full gains predictive."
$loops = @()
1..3 | ForEach-Object {
  $l = $_
  $useC = ($l -eq 3)
  $str = ($l -ge 2)
  $bias = if ($l -eq 1) {1.0} elseif ($l -eq 2) {1.12} else {1.22}
  $res = Get-IterLoopSim $l $useC $str $bias 60.0
  $loops += $res
  Write-Host ("LOOP {0}: useCrowd={1} strictSpd={2} biasTweak={3} -> #7 effMid={4} red={5} ROAD_MID%={6} dom={7} spd={8} rough={9} pers={10} ema={11} auxF={12} fields={13}" -f $l,$res.crowdBoost,$str,$bias,$res.effMid,$res.red,$res.domPct,$res.dom,$res.spd,$res.rough,$res.personal,$res.ema,$res.auxF,$res.fields )
}
