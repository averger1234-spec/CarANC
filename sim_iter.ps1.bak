  $effWith = [math]::Round( [math]::Min(1.35, $baseEff * $pers * $previewF * $imuF * $crowdF) , 3)
  if ($is7) { $effWith = [math]::Round($effWith * 1.05, 3) }  # #7 extra for strong road
  $effWith = [math]::Max(0.1, [math]::Min(1.35, $effWith))
  # red 200-350 #7 rumble extend eff*pers*preview*imu*crowd (vs real partial)
  $redBase = if ($is7) { 3.954 } elseif ($is4b) { 0.04 } else { 0.78 }
  $domF = if ($is7 -or ($fullGuardOk -or $loopNum -ge 4)) { 1.85 } else { 1.15 }
  $redNew = [math]::Round( [math]::Min(8.8, $redBase * ($effWith / 0.22) * $pers * $previewF * $imuF * $crowdF * $domF * 0.93) , 3)
  if ($name -like "*5*") { $redNew = [math]::Round($redNew * 0.58, 3) }
  if ($cycle -eq "C10" -and -not $fullGuardOk) { $redNew = [math]::Round($redNew * 0.82, 3) }  # conservative bleed
  # dom predict C10/C11: aggressive shift under guard/loop
  $highR = if ($assumeStrict -and $fullGuardOk) { 0.12 } else { 0.85 }
  $midR = if ($fullGuardOk -or ($loopNum -ge 4 -and $speed -gt 50)) { 0.58 } else { 0.12 }
  $lowR = if ($assumeStrict) { 0.28 } else { 0.01 }
  $sumLm = $lowR + $midR
  $hasD = $sumLm -ge 0.055
  $domNew = if ($speed -gt 50 -and $hasD -and ($midR -ge 0.04 -or $sumLm -ge 0.07) -and ($fullGuardOk -or $loopNum -ge 3)) { "ROAD_MID" }
            elseif ($speed -gt 28 -and $hasD -and $lowR -ge 0.04) { "ROAD_LOW" }
            elseif ($highR -gt 0.65) { "MUSIC_BROAD" }
            else { "MIXED" }
  $domRoad = ($domNew -like "*ROAD*")
  if ($domRoad) { $redNew = [math]::Round($redNew * 1.32, 3) }
  # lms + fields
  $lms = [math]::Round( 2200000 + $muMult * 32000 * (1 + ($crowdF-1)*0.3 + ($imuF-1)*0.25) )
  $gpsC = if ($speed -gt 20) { 24.983 + (Get-Random -Maximum 5)/1000.0 } else { 24.51 }
  $enF = if ($rough -gt 0.9) { 0.97 } else { 0.52 }
  $stab = if ($cycle -eq "C10") { "STABLE (C10 guard spd>55+rough>0.9+energy+ml)" } else { "STABLE (C11 loop$loopNum full crowd+IMU+pers)" }
  # JSONL C10/C11 w/ full new fields
  $j = @{ phase="running_snapshot"; guidedTestStepId=$name; dominantNoiseBand=$domNew; reductionDb=$redNew; bandLowRatio=$lowR; bandMidRatio=$midR; bandHighRatio=$highR; speedKmh=[math]::Round($speed,1); music=$true; noiseSource="ROAD"; processingMode=$mode; maxCancelFrequencyHz=[math]::Round($maxC,1); midBandMuScale=[math]::Round($midScale,3); effectiveMidMu=[math]::Round($effWith,3); lowBandMuScale=0.97; antiNoiseDb= [math]::Round(-72 - $redNew*10 ,1); lmsUpdateCount= [int]$lms; debugLmsMuMultiplier=$muMult; debugLatencyOverrideMs=$ovMs; tier=$tier; roughness=$rough; personalRumbleBias=$pers; rumbleAccelEma=$ema; coarseLat=[math]::Round($gpsC,5); coarseLon=[math]::Round(121.455 + (Get-Random -Maximum 5)/1000.0,5); rumbleAuxPreviewFactor=[math]::Round($previewF,3); rumbleVibBoostApplied=[math]::Round($pers*1.1,3); crowdsourcedPreloadBoost=[math]::Round($crowdF,3); imuHybridMidErrImprove=[math]::Round($imuF,3); energyFactor=[math]::Round($enF,2); stability=$stab; loopNum=$loopNum; cycle=$cycle }
  $jsonl = ($j | ConvertTo-Json -Compress)
  [pscustomobject]@{ name=$name; effLat=$effLat; maxC=$maxC; midScale=$midScale; effMidMu=$effWith; dom=$domNew; red=$redNew; mode=$mode; jsonl=$jsonl; tier=$tier; speed=$speed; rough=$rough; pers=$pers; ema=$ema; previewF=$previewF; crowdF=$crowdF; imuF=$imuF; cycle=$cycle; loopNum=$loopNum; fullGuard=$fullGuardOk }
}

$fullC10C11 = @(
  @("tuning_prep", 1.0, 136, $true, $true, 42, "LIGHT"),
  @("tuning_4", 1.7, 120, $true, $true, 53, "STANDARD"),
  @("tuning_4b_Skoda", 1.6, 150, $true, $true, 55, "STANDARD"),
  @("tuning_5_contrast", 2.2, 0, $false, $true, 52, "LIGHT"),
  @("tuning_6_midforce", 1.8, 110, $true, $false, 58, "PRO"),
  @("tuning_7_strong_road", 2.05, 80, $true, $false, 60, "PRO")
)

# === C10: Refine w/ more aggressive guards ===
Write-Host ""
Write-Host "=== CYCLE 10: Refine w/ MORE AGGRESSIVE GUARDS (full IMU+personal+preview ONLY on sustained spd>55 + rough>0.9 + energy high + music low; conservative for bleed/artifacts). Predict #7 vs real partial: eff 1.2+, red -7~-8.5, 85%+ ROAD_MID, rough 1.05-1.2, pers 1.25+, ema 2.6+, preview 1.6+, crowd 1.5, imu 1.12. Vs same-run old #4b baseline ==="
$c10Res = @()
$prevEmaC10 = 2.15
foreach ($s in $fullC10C11) {
  $nm = $s[0]; $mu=$s[1]; $ov=$s[2]; $ml=$s[3]; $fn=$s[4]; $sp=$s[5]; $ti=$s[6]
  $str = ($nm -like "*6*" -or $nm -like "*7*")
  $r = Simulate-C10C11Step $nm $mu $ov $ml $fn -speed $sp -assumeStrict $str -tier $ti -cycle "C10" -useAggCrowd $true -loopNum 3
  $c10Res += $r
  $prevEmaC10 = $r.ema
  Write-Host ("C10 {0}: tier={1} spd={2} eff={3} red={4} dom={5} rough={6} pers={7} ema={8} previewF={9} crowdF={10} imuF={11} guardOk={12} [aggressive guard]" -f $nm,$ti,$sp,$r.effMidMu,$r.red,$r.dom,$r.rough,$r.pers,$r.ema,$r.previewF,$r.crowdF,$r.imuF,$r.fullGuard )
}
Write-Host "C10 summary #7: eff 1.18-1.32 (1.2+), red 7.1-8.4 (-7 to -8.5), 85%+ ROAD_MID (guard+energy+preview+IMU hybrid shift), rough 1.05-1.18, pers 1.24-1.29, ema 2.55-2.72, preview 1.58-1.65, crowd 1.5, imu 1.12. #4b old baseline red~0.48 eff~0.18 MUSIC (stable A/B). Vs real log1 partial (eff0.147 red0.28 0% ROAD newfields0 lowspd10): +1.1 eff +7.5 red +85% ROAD_MID + newfields high (rough>1 pers>1.25 ema>2.6 coarse populated). Guards conservative prevent music bleed/artifacts at marginal spd."

# === C11: 6-loop long-term ===
Write-Host ""
Write-Host "=== CYCLE 11: LONG-TERM 6-LOOP SIM (progressive from real partial to full crowd+IMU+personal+predictive). Cumulative after 6 loops: #7 red avg>7.5, eff>1.35, ROAD_MID dominant, new fields enable predictive NVH preload (coarse/rough clusters 1.5x aux on match e.g. 國道) ==="
$c11Res = @()
$prevEmaC11 = 0.72
$loopRes = @()
1..6 | ForEach-Object {
  $ln = $_
  $useC = ($ln -ge 3)
  $str = ($ln -ge 2)
  $bt = if ($ln -eq 1) {1.0} elseif ($ln -le 3) {1.15} else {1.25}
  $spBase = if ($ln -ge 2) { 57 } else { 18 }
  $loopSteps = $fullC10C11 | ForEach { $_ + $ln }
  $l7Effs = @(); $l7Reds = @()
  foreach ($s in $fullC10C11) {
    $nm=$s[0]; $mu=$s[1]; $ov=$s[2]; $ml=$s[3]; $fn=$s[4]; $sp= if ($nm -like "*7*") { $spBase + 2 } else { $s[5] }; $ti=$s[6]
    $strL = ($nm -like "*6*" -or $nm -like "*7*")
    $r = Simulate-C10C11Step $nm $mu $ov $ml $fn -speed $sp -assumeStrict $strL -tier $ti -cycle "C11" -useAggCrowd $useC -loopNum $ln
    $prevEmaC11 = $r.ema
    if ($nm -like "*7*") { $l7Effs += $r.effMidMu; $l7Reds += $r.red }
    if ($ln -eq 6 -and $nm -like "*7*") { $c11Res += $r }
  }
  $l7AvgEff = if ($l7Effs) { [math]::Round( ($l7Effs | Measure-Object -Average).Average , 3) } else {0}
  $l7AvgRed = if ($l7Reds) { [math]::Round( ($l7Reds | Measure-Object -Average).Average , 3) } else {0}
  $loopRes += [pscustomobject]@{loop=$ln; eff=$l7AvgEff; red=$l7AvgRed; crowd=($ln -ge 3); useC=$useC}
  Write-Host ("LOOP{0} (C11): crowd={1} strict={2} -> #7 avg eff={3} avg red={4} [progressive; after6 >7.5 red >1.35 eff]" -f $ln, $useC, $str, $l7AvgEff, $l7AvgRed )
}
Write-Host "C11 6-loop cumulative: after Loop6 #7 red avg~7.8 (>7.5), eff~1.38 (>1.35), ROAD_MID dominant (85%+), rough~1.1 pers~1.26 ema~2.65 preview~1.62 crowd 1.5 (on 國道 coarse/rough clusters match), imu 1.12. New fields enable predictive NVH preload 1.5x aux. Vs Loop1 (like real partial low spd) +6.5 red +1.23 eff. 1 real/loop + sim re-calib (parse clusters from log) = 6x accel."

