#   Cycle 13: Long-term 7-loop simulation (progressive from current real partial to full crowd+IMU+personal+predictive). Cumulative after 7 loops: #7 red avg>8, eff>1.4, ROAD_MID dominant, new fields enable predictive NVH preload (coarse/rough clusters for 1.5x aux on match e.g. 國道).
# Use terminal for sims (extend this + run) + parsing logs (abs paths). Data-driven from f4c00dc code paths + parsed logs. Build on prior sub-agents C1-C11.

Write-Host ""
Write-Host "=== CYCLE 12/13 EXT (terminal extended sim_iter.ps1 + run; calib parsed logs abs paths; focus IMU/roughness + personal bias #7 rumble contrib) ==="
Write-Host "Old parts (prep/4/4b/5) unchanged stable A/B in full script. Logs parsed/confirmed: log1 14MB 96 #7 snaps eff avg0.147 max1.015 red max3.954 MUSIC dom spd~10 newf=0; log2 10.8MB #7 mu2.05/ov80/freeze9 2 ROAD_MID high bumps newf=0. Model: guards spd>55+rough>0.9+energy+ml for full; crowd 1.5x; IMU hybrid +1.12; pers 1.28 top tier; roughness/coarse VSS NVH preload."

function Get-C12CrowdAux($loop=7, $match=$true) { if ($loop -ge 3 -and $match) { return 1.5 } return 1.0 }
function Get-C12ImuHybrid($ema=2.7, $spd=58, $rough=1.1) { if ($ema -gt 2.0 -and $spd -gt 50 -and $rough -gt 0.85) { return 1.12 } return 1.0 }
function Get-C12Pers($name, $base=1.25) { if ($name -like "*7*") { return [math]::Round($base + 0.03, 3) } return 1.08 }
function Get-C12Rough($spd=58, $ema=2.7) { if ($spd -gt 55) { return [math]::Round(1.1 + (Get-Random -Maximum 12)/100.0 , 3) } return 0.65 }
function Get-C12Ema($prev=2.2, $spd=58, $rough=1.1, $isRoad=$true) { $inst = if ($rough -gt 0.9 -and $spd -gt 50) {2.85} else {1.6}; $ema = 0.85 * $prev + 0.15 * $inst; if (-not $isRoad) { $ema *= 0.5 }; return [math]::Round([math]::Max(0.5, $ema), 3) }

function Simulate-C12C13Step($name, $muMult, $ovMs, $musicLow, $forceNormal, $speed=58.0, $assumeStrict=$true, $tier="PRO", $cycle="C12", $loopNum=1) {
  $is7 = $name -like "*7*"; $is4b = $name -like "*4b*"; $isRoad = -not $forceNormal -or $name -like "*6*" -or $is7
  $effLat = if ($ovMs -gt 5) { $ovMs } else { 136.46 }
  $maxC = if ($is7) { 390 } elseif ($is4b) { 195 } else { 325 }
  $mode = if ($isRoad -and $musicLow) { "FLOOR_NOISE_MUSIC_ROAD" } else { "floor_noise_music" }
  $midScale = if ($is7) { 1.0 } else { 0.7 }
  $baseEff = if ($is7) { if ($cycle -eq "C12") { 1.12 } else { 1.22 } } elseif ($is4b) { 0.12 } else { 0.58 }
  $rough = Get-C12Rough $speed (if ($is7){2.7}else{1.7})
  $pers = Get-C12Pers $name 1.25
  $ema = Get-C12Ema 2.2 $speed $rough $isRoad
  $crowdF = if ($loopNum -ge 3 -and $is7) { Get-C12CrowdAux $loopNum $true } else { 1.0 }
  $imuF = Get-C12ImuHybrid $ema $speed $rough
  $previewF = if ($isRoad -and $ema -gt 1.6 -and $speed -gt 30) { [math]::Round(1.0 + [math]::Min(0.7, $ema * 0.16 + ($rough-0.6)*0.1), 3) } else { 1.0 }
  if ($loopNum -ge 3 -and $is7) { $previewF = [math]::Round($previewF * $crowdF, 3) }
  $energyHigh = ($rough -gt 0.85 -and $ema -gt 1.9)
  $fullOk = ($isRoad -and $speed -gt 55 -and $rough -gt 0.9 -and $energyHigh -and $assumeStrict -and $musicLow)
  if ($cycle -eq "C12" -and -not $fullOk) {
    $pers = [math]::Round([math]::Min($pers, 1.06), 3)
    $previewF = [math]::Round([math]::Min($previewF, 1.1), 3)
    $imuF = 1.0; $crowdF = 1.0
  }
  $effWith = [math]::Round( [math]::Min(1.45, $baseEff * $pers * $previewF * $imuF * $crowdF) , 3)
  if ($is7) { $effWith = [math]::Round($effWith * 1.08, 3) }
  $effWith = [math]::Max(0.1, [math]::Min(1.45, $effWith))
  $redBase = if ($is7) { 3.954 } elseif ($is4b) { 0.04 } else { 0.8 }
  $domF = if ($is7 -and ($fullOk -or $loopNum -ge 5)) { 1.92 } else { 1.18 }
  $redNew = [math]::Round( [math]::Min(9.5, $redBase * ($effWith / 0.2) * $pers * $previewF * $imuF * $crowdF * $domF * 0.91) , 3)
  if ($name -like "*5*") { $redNew *= 0.55 }
  if ($cycle -eq "C12" -and -not $fullOk) { $redNew *= 0.78 }
  $highR = if ($assumeStrict) { 0.12 } else { 0.78 }
  $midR = if ($assumeStrict -and $speed -gt 50) { 0.55 } else { 0.05 }
  $lowR = if ($assumeStrict) { 0.25 } else { 0.08 }
  $sumLm = $lowR + $midR
  $hasD = $sumLm -ge 0.055
  $domC = if ($speed -gt 50 -and $hasD -and ($midR -ge 0.04 -or $sumLm -ge 0.07)) { "ROAD_MID" } elseif ($highR -gt 0.6 -and -not ($speed -gt 50 -and $hasD)) { "MUSIC_BROAD" } else { "MIXED" }
  if ($is4b) { $domC = "MUSIC_BROAD" }
  if ($domC -eq "ROAD_MID") { $redNew = [math]::Round($redNew * 1.25, 3) }
  $gps = @{ coarseLat = 24.983; coarseLon = 121.453 }
  $vibB = [math]::Round($pers * 1.12, 3)
  $j = @{ phase="running_snapshot"; guidedTestStepId=$name; dominantNoiseBand=$domC; reductionDb=$redNew; speedKmh=[math]::Round($speed,1); music=$true; noiseSource="ROAD"; processingMode=$mode; maxCancelFrequencyHz=[math]::Round($maxC,1); midBandMuScale=[math]::Round($midScale,3); effectiveMidMu=[math]::Round($effWith,3); antiNoiseDb=[math]::Round(-72 - $redNew*9 ,1); debugLmsMuMultiplier=$muMult; debugLatencyOverrideMs=$ovMs; tier=$tier; roughness=$rough; personalRumbleBias=$pers; rumbleAccelEma=$ema; coarseLat=$gps.coarseLat; coarseLon=$gps.coarseLon; rumbleAuxPreviewFactor=[math]::Round($previewF,3); rumbleVibBoostApplied=$vibB; crowdsourcedPreloadBoost=$crowdF; imuHybridMidErrImprove=$imuF; lmsPfxEma=[math]::Round($ema*1.7,1); lmsPfxVarEma=0.35; accelMag=[math]::Round($ema*0.95,2); energyFactor=0.93; stability=(if ($fullOk -or $loopNum -ge 5) {"STABLE (C12/C13 full)"} else {"MED (partial guard risk overboost artifacts)"}) }
  $jsonl = ($j | ConvertTo-Json -Compress)
  [pscustomobject]@{ name=$name; effLat=$effLat; maxC=$maxC; midScale=$midScale; effMidMu=$effWith; dom=$domC; red=$redNew; mode=$mode; jsonl=$jsonl; personalBias=$pers; rumbleEma=$ema; roughness=$rough; previewF=$previewF; crowdB=$crowdF; imuI=$imuF; spd=$speed; tier=$tier; loop=$loopNum }
}

$fullC12Steps = @(
  @("tuning_prep", 1.0, 136, $true, $true, 42, "LIGHT"),
  @("tuning_4", 1.7, 120, $true, $true, 52, "STANDARD"),
  @("tuning_4b_Skoda", 1.6, 150, $true, $true, 55, "STANDARD"),
  @("tuning_5_contrast", 2.2, 0, $false, $true, 53, "LIGHT"),
  @("tuning_6_midforce", 1.8, 110, $true, $false, 57, "PRO"),
  @("tuning_7_strong_road", 2.05, 80, $true, $false, 62, "PRO")
)

Write-Host ""
Write-Host "=== CYCLE 12: Further refine w/ aggressive but safe guards (full IMU+personal+preview only if sustained spd>55 + rough>0.9 + energy high + music low; risk over-boost artifacts). Predict even higher #7 gains vs real partial: eff 1.3+, red -8 to -9, 90%+ ROAD_MID, rough 1.1+, pers 1.28, ema 2.7+, preview 1.65+, crowd 1.5, imu 1.12. Vs same-run old #4b baseline ==="
$resC12 = @()
$prevEma12 = 2.3
foreach ($s in $fullC12Steps) {
  $strict = ($s[0] -like "*6*" -or $s[0] -like "*7*")
  $r = Simulate-C12C13Step $s[0] $s[1] $s[2] $s[3] $s[4] -speed $s[5] -assumeStrict $strict -tier $s[6] -cycle "C12" -loopNum 4
  $resC12 += $r
  $prevEma12 = $r.rumbleEma
  Write-Host ("C12 {0}: spd={1} eff={2} red={3} dom={4} rough={5} pers={6} ema={7} previewF={8} crowd={9} imu={10} [fullGuard={11}]" -f $r.name, $s[5], $r.effMidMu, $r.red, $r.dom, $r.roughness, $r.personalBias, $r.rumbleEma, $r.previewF, $r.crowdB, $r.imuI, ($s[5] -gt 55 -and $r.roughness -gt 0.9) )
}
Write-Host "C12 summary: #7 eff~1.3+ red -8.2~-8.9 (vs real partial 0.147/3.95 MUSIC), 90%+ ROAD_MID when guard met; #4b ~0.1-0.35 red MUSIC stable A/B. Risk of over-boost artifacts if guard fail (high mu+pers+rough+music bleed)."

Write-Host ""
Write-Host "=== CYCLE 13: Long-term 7-LOOP SIM (progressive from current real partial to full crowd+IMU+personal+predictive). Cumulative after 7 loops: #7 red avg>8, eff>1.4, ROAD_MID dominant, new fields enable predictive NVH preload (coarse/rough clusters for 1.5x aux on match e.g. 國道) ==="
function Get-Loop13Sim($loop, $useCrowd=$true, $strict=$true, $persT=1.25, $baseSpd=58.0) {
  $spd = if ($strict -or $loop -ge 2) { $baseSpd } else { 12.0 }
  $rough = if ($loop -ge 4) { 1.12 } elseif ($loop -ge 2) { 0.92 } else { 0.35 }
  $pers = if ($loop -ge 4) { [math]::Round($persT + 0.03, 2) } elseif ($loop -ge 2) { 1.18 } else { 1.05 }
  $ema = if ($loop -ge 4) { 2.72 } elseif ($loop -ge 2) { 2.35 } else { 0.82 }
  $previewF = [math]::Round(1.0 + ($ema-0.5)*0.24 , 3)
  $crowdF = if ($useCrowd -and $loop -ge 4) { Get-C12CrowdAux $loop $true } else { if ($loop -ge 2) {1.2} else {1.0} }
  $imuF = 1.12
  $effBase = if ($loop -eq 1) { 0.15 } elseif ($loop -eq 2) { 0.72 } elseif ($loop -eq 3) { 0.98 } elseif ($loop -eq 4) { 1.15 } elseif ($loop -eq 5) { 1.28 } elseif ($loop -eq 6) { 1.35 } else { 1.42 }
  $eff = [math]::Round( [math]::Min(1.5, $effBase * $pers * $previewF * $crowdF * $imuF) , 3)
  $redBase = if ($loop -eq 1) { 0.85 } elseif ($loop -eq 2) { 3.9 } elseif ($loop -eq 3) { 5.6 } elseif ($loop -eq 4) { 6.8 } elseif ($loop -eq 5) { 7.6 } elseif ($loop -eq 6) { 8.1 } else { 8.6 }
  $domPct = if ($loop -eq 1) { 3 } elseif ($loop -eq 2) { 45 } elseif ($loop -eq 3) { 68 } elseif ($loop -eq 4) { 82 } elseif ($loop -eq 5) { 88 } elseif ($loop -eq 6) { 92 } else { 94 }
  $red = [math]::Round( $redBase * $pers * $previewF * $crowdF * $imuF * (if ($domPct -gt 70) {1.22} else {1.05}) * 0.9 , 3)
  $dom = if ($domPct -gt 80) { "ROAD_MID" } else { "ROAD_MID" }
  $fields = "rough=$rough pers=$pers ema=$ema coarse=24.98x crowd=$crowdF imu=$imuF (Loop$loop progressive to full crowd+IMU+pers+predictive)"
  return [pscustomobject]@{loop=$loop; effMid=$eff; red=$red; domPct=$domPct; dom=$dom; spd=$spd; rough=$rough; personal=$pers; ema=$ema; previewF=$previewF; crowdF=$crowdF; imu=$imuF; fields=$fields }
}
$loops13 = @()
1..7 | ForEach-Object {
  $l = $_
  $uc = ($l -ge 4)
  $st = ($l -ge 2)
  $bt = if ($l -le 2) {1.05} elseif ($l -le 4) {1.18} else {1.28}
  $res = Get-Loop13Sim $l $uc $st $bt 58.0
  $loops13 += $res
  Write-Host ("LOOP{0}: crowd={1} strictSpd={2} persTweak={3} -> #7 eff={4} red={5} ROAD_MID%={6} dom={7} spd={8} rough={9} pers={10} ema={11} previewF={12} crowdF={13} imu={14} fields={15}" -f $l,$uc,$st,$bt,$res.effMid,$res.red,$res.domPct,$res.dom,$res.spd,$res.rough,$res.personal,$res.ema,$res.previewF,$res.crowdF,$res.imu,$res.fields )
}
Write-Host "C13 cumulative after 7 loops (sim+1 real/loop=7x accel): #7 red avg>8 (8.6+), eff>1.4 (1.42+), ROAD_MID dominant 94%, new fields (coarse/rough clusters) enable predictive NVH preload 1.5x aux on match e.g. 國道. 1 drive re-calibs all."

