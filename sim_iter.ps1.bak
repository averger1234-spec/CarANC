  @("tuning_7_idle", 2.05, $true)
)
foreach ($c in $idleCases) {
  $nm = $c[0]; $mu=$c[1]; $ml=$c[2]
  $risk = Predict-IdleRisk $mu $ml
  Write-Host ("{0}: mu={1} musicLow={2} -> artifactRisk={3}" -f $nm, $mu, $ml, $risk)
}
