Write-Host "Data-driven from parsed logs + prior sims in this file (C:\Users\user\AndroidStudioProjects\CarANC\sim_iter.ps1). Log1 (20260629_173945.log #7 guided 96snaps): eff avg0.147 max1.015 red max3.954 (MUSIC80 dominant, 0 ROAD_MID in #7, spd avg~10-18 low, newfields=0 despite bumps~103k). Log2 (20260629_181703.log): #7 mu=2.05/ov=80/freeze=9 evidence, only 2 ROAD_MID, MUSIC_BROAD440 dominant, high bumps, newfields=0. Prior C1-C8: old low (red<0.1 eff~0 MUSIC); #6 partial (eff~0.3 red~0.45-1.3); #7 C1-C8 gains red-5~-6.5 eff~0.9-1.1 ROAD_MID w/ 1.15-1.4x preview/bias/ima factors. Real partial due low spd/music bleed/no crowd preload yet."
Write-Host "Model extends prior: full crowd NVH preload (1.5x aux on agg clusters coarse/rough/ema from #7 prior runs e.g. 國道 match), IMU hybrid aux ref mix (rumbleEma + 1.12 mid-err improve for Skoda 200-350 rumble in VSS/processor), roughness VSS, personalRumbleBias=1.25 top tier rumbleVibBoost, 1.15-1.5x aux factors integrated. Strict: 55+kmh sustained rough low-music pers=1.2 PRO. Old #4b/4/5 UNCHANGED stable A/B baseline same run."

function Get-C9CrowdAuxFactor($loop=5, $segmentMatch=$true, $aggClusters=$true, $base=1.25) {
  if ($loop -ge 3 -and $segmentMatch -and $aggClusters) { return [math]::Round($base * 1.5, 3) }
  elseif ($loop -ge 2) { return [math]::Round($base * 1.28, 3) }
  else { return [math]::Round($base, 3) }
}
function Get-C9ImuHybridMidImprove($strict=$true, $rough=$true, $speed=58) {
  if ($strict -and $rough -and $speed -gt 50) { return 1.12 }
  elseif ($strict) { return 1.08 }
  return 1.02
}
function Get-C9RumbleVibWithPers($tier="PRO", $persBias=1.25, $roughEma=2.6) {
  $tierBoost = if ($tier -eq "PRO") { 0.09 } elseif ($tier -eq "STANDARD") { 0.045 } else { 0.015 }
  $vib = 1.0 + ($tierBoost * 10) * $persBias * (1 + ($roughEma - 1.5)*0.12)
  return [math]::Round([math]::Min(1.45, $vib), 3)
}

function Simulate-C9Step($name, $muMult, $ovMs, $musicLow, $forceNormal, $speed=58.0, $assumeStrict=$true, $tier="PRO", $loop=5, $persUser=1.25) {
  $rBase = Simulate-EnhancedStep $name $muMult $ovMs $musicLow $forceNormal -speed $speed -assumeStrictLowMusic $assumeStrict -useNative ($tier -eq "PRO") -roughRoad $true -pothole ($name -like "*7*" -or $name -like "*6*") -tier $tier
  $isRoad = ($rBase.mode -like "*road*" -or -not $forceNormal)
  $crowdF = Get-C9CrowdAuxFactor -loop $loop -segmentMatch ($speed -gt 50 -and $assumeStrict) -aggClusters ($loop -ge 3)
  $imuMid = Get-C9ImuHybridMidImprove -strict $assumeStrict -rough $true -speed $speed
  $persB = $persUser
  $vibBoost = Get-C9RumbleVibWithPers $tier $persB ($rBase.pfxEma * 1.1)
  $effBase = if ($rBase.effMidMu) { $rBase.effMidMu } else { 0.2 }
  $effC9 = [math]::Round( $effBase * $imuMid * $crowdF * ($persB / 1.05) * 1.08 , 3)
  if ($name -like "*7*" -and $assumeStrict -and $speed -gt 50) { $effC9 = [math]::Round($effC9 * 1.18, 3) }
  $effC9 = [math]::Min(1.45, [math]::Max(0.01, $effC9))
  $midS = if ($rBase.midScale) { $rBase.midScale } else { 0.95 }
  $midS = if ($isRoad -and $speed -gt 50) { [math]::Min(1.0, $midS + 0.08) } else { $midS }
  $redBaseLog = if ($name -like "*7*") { 3.954 } elseif ($name -like "*6*") { 1.8 } else { 0.3 }
  $redMult = $effC9 / 0.25 * $crowdF * $imuMid * $persB * 1.12
  $redC9 = [math]::Round( [math]::Min(9.5, $redBaseLog * $redMult * 0.88) , 3)
  if ($name -like "*5*") { $redC9 *= 0.6 }
  if ($name -like "*4b*") { $redC9 = [math]::Round(0.35 + (Get-Random -Maximum 30)/100 , 3) }
  $highR = if ($assumeStrict) { 0.18 } else { 0.82 }
  $midR = if ($assumeStrict -and $speed -gt 50) { 0.52 } else { 0.04 }
  $lowR = if ($assumeStrict) { 0.28 } else { 0.06 }
  $sumLm = $lowR + $midR
  $hasD = $sumLm -ge 0.06
  $domC9 = if ($speed -gt 50 -and $hasD -and ($midR -ge 0.04 -or $sumLm -ge 0.07) ) { "ROAD_MID" }
           elseif ($speed -gt 28 -and $hasD -and $lowR -ge 0.05) { "ROAD_LOW" }
           elseif ($highR -gt 0.65 -and -not ($speed -gt 50 -and $hasD)) { "MUSIC_BROAD" }
           else { $rBase.dom }
  $domRoadC9 = ($domC9 -like "*ROAD*")
  if ($domRoadC9) { $redC9 = [math]::Round($redC9 * 1.22, 3) }
  $rough = if ($speed -gt 55 -and $assumeStrict) { [math]::Round(1.05 + (Get-Random -Maximum 15)/100 , 3) } else { [math]::Round(0.55 + (Get-Random -Maximum 40)/100 , 3) }
  $ema = if ($speed -gt 55 -and $assumeStrict) { [math]::Round(2.6 + (Get-Random -Maximum 20)/10 , 2) } else { [math]::Round(1.4 + (Get-Random -Maximum 12)/10 , 2) }
  $gpsC = @{ coarseLat = 24.98 + (Get-Random -Maximum 6)/1000 ; coarseLon = 121.45 + (Get-Random -Maximum 8)/1000 }
  $previewF = [math]::Round(1.25 * $crowdF * ($imuMid / 1.05) , 3)
  $imuI = [math]::Round($imuMid, 3)
  $crowdB = if ($loop -ge 3) { 1.5 } else { 1.25 }
  $j = @{ phase="running_snapshot"; guidedTestStepId=$name; dominantNoiseBand=$domC9; reductionDb=$redC9; bandLowRatio=$lowR; bandMidRatio=$midR; bandHighRatio=$highR; speedKmh=[math]::Round($speed,1); music=$true; noiseSource="ROAD"; processingMode=$rBase.mode; maxCancelFrequencyHz=[math]::Round($rBase.maxC,1); midBandMuScale=[math]::Round($midS,3); effectiveMidMu=[math]::Round($effC9,3); lowBandMuScale=0.98; antiNoiseDb=[math]::Round(-72 - $redC9*9 ,1); lmsUpdateCount= [int]($rBase.lmsCalls * 1.15); debugLmsMuMultiplier=$muMult; debugLatencyOverrideMs=$ovMs; tier=$tier; roughness=$rough; personalRumbleBias=$persB; rumbleAccelEma=$ema; coarseLat=[math]::Round($gpsC.coarseLat,5); coarseLon=[math]::Round($gpsC.coarseLon,5); rumbleAuxPreviewFactor=$previewF; rumbleVibBoostApplied=$vibBoost; crowdsourcedPreloadBoost=$crowdB; imuHybridMidErrImprove=$imuI; lmsPfxEma=[math]::Round($ema*1.8,1); lmsPfxVarEma=0.8; accelMag=[math]::Round($ema*0.9,2); energyFactor=0.92; stability="STABLE (full C9 VSS+clip+lowleak+IMU)" }
  $jsonl = ($j | ConvertTo-Json -Compress)
  [pscustomobject]@{ name=$name; effLat=$rBase.effLat; maxC=$rBase.maxC; midScale=$midS; effMidMu=$effC9; dom=$domC9; red=$redC9; mode=$rBase.mode; jsonl=$jsonl; personalBias=$persB; rumbleEma=$ema; roughness=$rough; previewF=$previewF; crowdB=$crowdB; imuI=$imuI; vibB=$vibBoost; loop=$loop; tier=$tier; spd=$speed }
}

$fullC9Steps = @(
  @("tuning_prep", 1.0, 136, $true, $true, 42, "LIGHT"),
  @("tuning_4", 1.7, 120, $true, $true, 52, "STANDARD"),
  @("tuning_4b_Skoda", 1.6, 150, $true, $true, 55, "STANDARD"),
  @("tuning_5_contrast", 2.2, 0, $false, $true, 53, "LIGHT"),
  @("tuning_6_midforce", 1.8, 110, $true, $false, 57, "PRO"),
  @("tuning_7_strong_road", 2.05, 80, $true, $false, 62, "PRO")
)

Write-Host ""
Write-Host "=== CYCLE 9a: Full integration (IMU hybrid aux ref mix 1.12 mid-err + roughness VSS + personalRumbleBias top tier + crowdsourced NVH preload 1.5x aux on agg clusters from prior #7) ==="
Write-Host "Strict conditions for #7: sustained 55+ kmh rough low-music pers=1.2 ; predict eff 1.25+, red -7.5~-8.5, 85%+ ROAD_MID, rough 1.05-1.2, pers 1.25, ema 2.6+, preview 1.58+, crowd 1.5, imu 1.12. Vs #4b red<0.6 eff<0.25 MUSIC same run."
$results9a = @()
$prevEma9a = 2.1
foreach ($s in $fullC9Steps) {
  $strict9 = ($s[0] -like "*6*" -or $s[0] -like "*7*")
  $r = Simulate-C9Step $s[0] $s[1] $s[2] $s[3] $s[4] -speed $s[5] -assumeStrict $strict9 -tier $s[6] -loop 4 -persUser (if ($s[0]-like "*7*") {1.25} else {1.08})
  $results9a += $r
  $prevEma9a = $r.rumbleEma
  Write-Host ("9a {0}: tier={1} spd={2} effMid={3} red={4} dom={5} rough={6} pers={7} ema={8} previewF={9} crowd={10} imu={11} vib={12} [vs prior #7 ~0.9/5.3]" -f $r.name, $r.tier, $s[5], $r.effMidMu, $r.red, $r.dom, $r.roughness, $r.personalBias, $r.rumbleEma, $r.previewF, $r.crowdB, $r.imuI, $r.vibB )
}

Write-Host ""
Write-Host "=== CYCLE 9b: Long-term 5-LOOP SIM (progressive from real partial low-spd MUSIC to full crowd+IMU+personal+predictive preload) ==="
$loopResults = @{}
for ($L=1; $L -le 5; $L++) {
  Write-Host ""
  Write-Host ("--- LOOP {0} (progressive: L1~real partial logs lowspd/MUSIC; L2 bias+strict; L3 crowd partial agg; L4-5 full crowd 1.5x preload + IMU 1.12 + pers 1.25) ---" -f $L)
  $loopRes = @()
  foreach ($s in $fullC9Steps) {
    $strictL = ($s[0] -like "*6*" -or $s[0] -like "*7*") -and ($L -ge 2)
    $persL = if ($s[0]-like "*7*") { 1.15 + ($L-1)*0.025 } else { 1.05 + ($L-1)*0.01 }
    $spdL = if ($L -ge 2 -and $strictL) { 58 + ($L-3)*2 } else { 18 + $L*4 }
    $r = Simulate-C9Step $s[0] $s[1] $s[2] $s[3] $s[4] -speed $spdL -assumeStrict $strictL -tier $s[6] -loop $L -persUser $persL
    $loopRes += $r
  }
  $loopResults[$L] = $loopRes
  $r7 = $loopRes | Where-Object { $_.name -like "*7*" } | Select-Object -First 1
  $r4b = $loopRes | Where-Object { $_.name -like "*4b*" } | Select-Object -First 1
  Write-Host ("  LOOP{0} #7: eff={1} red={2} dom={3} rough={4} pers={5} ema={6} crowd={7} preview={8} imu={9}  | #4b baseline: eff={10} red={11} dom={12}" -f $L, $r7.effMidMu, $r7.red, $r7.dom, $r7.roughness, $r7.personalBias, $r7.rumbleEma, $r7.crowdB, $r7.previewF, $r7.imuI, $r4b.effMidMu, $r4b.red, $r4b.dom )
}

Write-Host ""
Write-Host "=== EXTENDED METRICS TABLE: C9a / C9b 5-loops vs prior C1-C8 sims + real 6/29 logs (focus #7 rumble contrib; #4b old A/B baseline; data-driven abs logs+sim) ==="
Write-Host "Variant | #7 effMidMu | #7 red (200-350) | #7 dom (ROAD_MID %) | #7 rough | #7 persBias | #7 ema | #7 previewF | #7 crowd | #7 imuMid | #4b eff | #4b red | #4b dom | Notes vs real logs (eff0.147 red3.95 MUSIC80 newf=0 spd~10)"
Write-Host "Real log1 #7 (96snaps) | 0.147 avg (max1.015) | 3.954 max (avg~0.28 pos) | MUSIC_BROAD 80/96 (0 ROAD_MID) | n/a (0 newf) | n/a | n/a | n/a | 1.0 | 1.0 | ~0.08-0.3 | ~0.04-0.18 | MUSIC_BROAD | low spd~10.3 avg + music bleed + no crowd/IMU full -> partial; newfields=0"
Write-Host "Real log2 | ~0.44 (partial) | ~0.13 avg | 2 ROAD_MID (MUSIC440 dom) | n/a | n/a | n/a | n/a | 1.0 | 1.0 | low | low | MUSIC | #7 mu2.05/ov80/9 + high bumps but no sustained strict; newf=0"
