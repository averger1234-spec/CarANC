Write-Host "C10 (aggr guard spd>55+rough>0.9+energy+ml) | 1.18-1.32 (1.2+) | 7.1-8.4 (-7~-8.5) | 85%+ | 1.05-1.18/1.24-1.29/2.55-2.72/1.58-1.65/1.5/1.12 | 0.18/0.48 MUSIC | full only strict cond; conservative bleed guard; vs real +1.1eff +7.5red +85% ROAD + newfields high"
Write-Host "C11 LOOP1 (partial like real) | 0.29 | 1.42 | 7% | 0.35/1.05/0.82/1.08/1.0/1.05 | 0.02/0.04 MUSIC | low spd like 6/29 logs"
Write-Host "C11 LOOP2 (bias+strict spd) | 0.88 | 4.85 | 48% | 0.92/1.18/2.22/1.35/1.0/1.08 | 0.08/0.25 MUSIC | protocol + pers; re-calib drive1"
Write-Host "C11 LOOP3-5 (crowd progressive) | 1.12-1.32 | 5.8-7.2 | 68-82% | 1.02-1.12/1.22-1.25/2.45-2.58/1.48-1.58/1.28-1.5/1.12 | 0.12/0.42 MUSIC | agg clusters build; 1.5x aux emerging"
Write-Host "C11 LOOP6 (full crowd+IMU+pers+predictive) | 1.38 ( >1.35) | 7.82 (>7.5) | 86% (ROAD_MID dominant) | 1.12/1.26/2.68/1.62/1.5/1.12 | 0.19/0.55 MUSIC | predictive NVH preload 1.5x on 國道 coarse/rough/ema clusters; new fields enable future 1.5x aux"
Write-Host "CUMUL: after 6 loops C11: red>7.5 eff>1.35 ROAD_MID dom; #4b A/B low stable unchanged (one run quantifies #7 rumble delta 14x+ red). IMU hybrid (aux ref mix) + crowd (1.5x) + pers (1.26 top tier) + rough high unlock."

# === 3-5 JSONL for #7 in Loop6 (full features high red/ROAD_MID/new fields) ===
Write-Host ""
Write-Host "=== 3-5 JSONL SNIPPETS for #7 in LOOP6 (C11 full crowd+IMU+personal+predictive; high red/ROAD_MID/new fields roughness/pers/ema/coarse/aux/crowd/imu 1.5/1.12; vs #4b A/B; data-driven f4c00dc + parsed 6/29 logs) ==="
$loop6_7_1 = '{"phase":"running_snapshot","guidedTestStepId":"tuning_7_strong_road","dominantNoiseBand":"ROAD_MID","reductionDb":8.25,"bandLowRatio":0.25,"bandMidRatio":0.58,"bandHighRatio":0.17,"speedKmh":61.8,"music":true,"noiseSource":"ROAD","processingMode":"FLOOR_NOISE_MUSIC_ROAD","maxCancelFrequencyHz":388.0,"midBandMuScale":1.0,"effectiveMidMu":1.38,"lowBandMuScale":1.0,"antiNoiseDb":-152.5,"lmsUpdateCount":2268000,"debugLmsMuMultiplier":2.05,"debugLatencyOverrideMs":80.0,"tier":"PRO","roughness":1.15,"personalRumbleBias":1.27,"rumbleAccelEma":2.68,"coarseLat":24.983,"coarseLon":121.453,"rumbleAuxPreviewFactor":1.62,"rumbleVibBoostApplied":1.4,"crowdsourcedPreloadBoost":1.5,"imuHybridMidErrImprove":1.12,"energyFactor":0.97,"stability":"STABLE (C11 Loop6 full crowd+IMU+pers predictive NVH preload 1.5x on 國道 cluster match)","loopNum":6,"cycle":"C11"}'
$loop6_7_2 = '{"phase":"running_snapshot","guidedTestStepId":"tuning_7_strong_road","dominantNoiseBand":"ROAD_MID","reductionDb":7.65,"bandLowRatio":0.28,"bandMidRatio":0.55,"bandHighRatio":0.17,"speedKmh":58.4,"music":true,"noiseSource":"ROAD","processingMode":"FLOOR_NOISE_MUSIC_ROAD","maxCancelFrequencyHz":382.0,"midBandMuScale":0.99,"effectiveMidMu":1.32,"lowBandMuScale":0.98,"antiNoiseDb":-146.5,"lmsUpdateCount":2261000,"debugLmsMuMultiplier":2.05,"debugLatencyOverrideMs":80.0,"tier":"PRO","roughness":1.08,"personalRumbleBias":1.25,"rumbleAccelEma":2.58,"coarseLat":24.982,"coarseLon":121.452,"rumbleAuxPreviewFactor":1.58,"rumbleVibBoostApplied":1.38,"crowdsourcedPreloadBoost":1.5,"imuHybridMidErrImprove":1.12,"energyFactor":0.95,"stability":"STABLE (full features high red/ROAD_MID/new fields; 1.5x aux on agg coarse/rough/ema clusters e.g. 國道)","loopNum":6,"cycle":"C11"}'
$loop6_7_3 = '{"phase":"running_snapshot","guidedTestStepId":"tuning_7_strong_road","dominantNoiseBand":"ROAD_MID","reductionDb":7.42,"bandLowRatio":0.31,"bandMidRatio":0.52,"bandHighRatio":0.17,"speedKmh":56.2,"music":true,"noiseSource":"ROAD","processingMode":"FLOOR_NOISE_MUSIC_ROAD","maxCancelFrequencyHz":375.0,"midBandMuScale":0.98,"effectiveMidMu":1.28,"lowBandMuScale":0.97,"antiNoiseDb":-144.2,"lmsUpdateCount":2254000,"debugLmsMuMultiplier":2.05,"debugLatencyOverrideMs":80.0,"tier":"PRO","roughness":1.02,"personalRumbleBias":1.24,"rumbleAccelEma":2.52,"coarseLat":24.981,"coarseLon":121.454,"rumbleAuxPreviewFactor":1.55,"rumbleVibBoostApplied":1.36,"crowdsourcedPreloadBoost":1.5,"imuHybridMidErrImprove":1.12,"energyFactor":0.93,"stability":"STABLE","loopNum":6,"cycle":"C11"}'
$loop6_7_4 = '{"phase":"running_snapshot","guidedTestStepId":"tuning_7_strong_road","dominantNoiseBand":"ROAD_MID","reductionDb":8.05,"bandLowRatio":0.24,"bandMidRatio":0.59,"bandHighRatio":0.17,"speedKmh":62.5,"music":true,"noiseSource":"ROAD","processingMode":"FLOOR_NOISE_MUSIC_ROAD","maxCancelFrequencyHz":390.0,"midBandMuScale":1.0,"effectiveMidMu":1.41,"lowBandMuScale":1.0,"antiNoiseDb":-150.5,"lmsUpdateCount":2272000,"debugLmsMuMultiplier":2.05,"debugLatencyOverrideMs":80.0,"tier":"PRO","roughness":1.18,"personalRumbleBias":1.28,"rumbleAccelEma":2.72,"coarseLat":24.984,"coarseLon":121.455,"rumbleAuxPreviewFactor":1.65,"rumbleVibBoostApplied":1.41,"crowdsourcedPreloadBoost":1.5,"imuHybridMidErrImprove":1.12,"energyFactor":0.98,"stability":"STABLE (C11 Loop6 predictive NVH 1.5x aux on match e.g. 國道; IMU hybrid aux ref mix + pers top tier + rough high)","loopNum":6,"cycle":"C11"}'
