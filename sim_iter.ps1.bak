function Get-C10CrowdAuxFactor($aggRuns=5, $roughHigh=$true, $coarseMatch=$true, $emaHigh=$true) {
  if ($aggRuns -ge 3 -and $roughHigh -and $coarseMatch -and $emaHigh) { return 1.5 }
  return 1.0
}

function Get-C10ImuHybrid($rumbleEma=2.6, $spd=58, $rough=1.1) {
  if ($rumbleEma -gt 2.0 -and $spd -gt 50 -and $rough -gt 0.8) { return 1.12 }
  return 1.0
}

function Get-C10PersonalBias($name, $tier="PRO", $base=1.25) {
  if ($name -like "*7*") { return [math]::Round($base + (Get-Random -Maximum 6)/100.0, 3) }
  return if ($tier -eq "PRO") { 1.08 } else { 1.02 }
}

function Get-C10Roughness($spd, $ema, $poth=$true) {
  $b = if ($poth -and $spd -gt 50) { 1.08 } elseif ($spd -gt 50) { 0.92 } elseif ($ema -gt 1.5) { 0.68 } else { 0.35 }
  return [math]::Round([math]::Max(0.3, $b + (Get-Random -Maximum 22)/100.0 - 0.05), 3)
}

function Get-C10RumbleEma($prev, $spd, $rough, $isRoad) {
  $inst = [math]::Round( (if ($rough -gt 0.9 -and $spd -gt 50) {2.65} else {1.4}) + (Get-Random -Maximum 12)/10.0 , 2)
  $ema = 0.85 * $prev + 0.15 * $inst
  if (-not $isRoad) { $ema *= 0.55 }
  return [math]::Round([math]::Max(0.4, $ema), 3)
}

function Simulate-C10C11Step($name, $muMult, $ovMs, $musicLow, $forceNormal, $speed=58.0, $assumeStrict=$true, $tier="PRO", $cycle="C10", $useAggCrowd=$true, $loopNum=1) {
  $is7 = $name -like "*7*"
  $is4b = $name -like "*4b*"
  $isRoad = -not $forceNormal -or $name -like "*6*" -or $is7
  $effLat = if ($ovMs -gt 5) { $ovMs } else { 136.46 }
  $maxC = if ($is7) { 385 } elseif ($is4b) { 195 } else { 320 }
  $mode = if ($isRoad -and $musicLow) { "FLOOR_NOISE_MUSIC_ROAD" } else { "floor_noise_music" }
  $midScale = if ($is7 -or $isRoad) { 0.99 } else { 0.65 }
  # Base eff from prior C9 model + f4c00dc
  $baseEff = if ($is7) { if ($cycle -eq "C10") { 1.05 } else { 1.18 } } elseif ($is4b) { 0.15 } else { 0.55 }
  $rough = Get-C10Roughness $speed (if ($is7) {2.6} else {1.6}) $is7
  $pers = Get-C10PersonalBias $name $tier 1.25
  $ema = Get-C10RumbleEma 2.1 $speed $rough $isRoad
  $crowdF = if ($useAggCrowd -and $is7 -and $loopNum -ge 3) { Get-C10CrowdAuxFactor 5 ($rough -gt 0.9) $true ($ema -gt 2.3) } else { 1.0 }
  $imuF = Get-C10ImuHybrid $ema $speed $rough
  # Preview aux mix (IMU hybrid Road Preview from ReferenceSignalPipeline)
  $previewF = if ($isRoad -and $ema -gt 1.5 -and $speed -gt 30) { [math]::Round(1.0 + [math]::Min(0.65, $ema * 0.15 + ($rough - 0.6)*0.12), 3) } else { 1.0 }
  if ($useAggCrowd -and $is7) { $previewF = [math]::Round($previewF * $crowdF, 3) }
  # C10 aggressive guards: FULL IMU+personal+preview ONLY sustained spd>55 + rough>0.9 + energy high + music low
  $energyHigh = ($rough -gt 0.85 -and $ema -gt 1.8)
  $fullGuardOk = ($isRoad -and $speed -gt 55 -and $rough -gt 0.9 -and $energyHigh -and $assumeStrict -and $musicLow)
  if ($cycle -eq "C10" -and -not $fullGuardOk) {
    $pers = [math]::Round([math]::Min($pers, 1.08), 3)
    $previewF = [math]::Round([math]::Min($previewF, 1.12), 3)
    $imuF = 1.0
    $crowdF = 1.0
  }

