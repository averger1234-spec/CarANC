$loop4_7_json1 = '{"phase":"running_snapshot","guidedTestStepId":"tuning_7_strong_road","dominantNoiseBand":"ROAD_MID","reductionDb":7.25,"bandLowRatio":0.28,"bandMidRatio":0.52,"bandHighRatio":0.20,"speedKmh":60.2,"music":true,"noiseSource":"ROAD","processingMode":"FLOOR_NOISE_MUSIC_ROAD","maxCancelFrequencyHz":385.0,"midBandMuScale":0.99,"effectiveMidMu":1.28,"lowBandMuScale":0.98,"antiNoiseDb":-142.5,"lmsUpdateCount":2258000,"debugLmsMuMultiplier":2.05,"debugLatencyOverrideMs":80.0,"tier":"PRO","roughness":1.12,"personalRumbleBias":1.25,"rumbleAccelEma":2.65,"coarseLat":24.983,"coarseLon":121.453,"rumbleAuxPreviewFactor":1.58,"rumbleVibBoostApplied":1.38,"crowdsourcedPreloadBoost":1.5,"imuHybridMidErrImprove":1.12,"lmsPfxEma":19.8,"lmsPfxVarEma":0.42,"accelMag":2.82,"energyFactor":0.94,"stability":"STABLE (C7b Loop4 full)"}'
