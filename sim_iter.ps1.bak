$loop6_4b = '{"phase":"running_snapshot","guidedTestStepId":"tuning_4b_Skoda","dominantNoiseBand":"MUSIC_BROAD","reductionDb":0.55,"bandLowRatio":0.14,"bandMidRatio":0.12,"bandHighRatio":0.74,"speedKmh":54.8,"music":true,"noiseSource":"ROAD","processingMode":"normal","maxCancelFrequencyHz":196.0,"midBandMuScale":0.42,"effectiveMidMu":0.19,"lowBandMuScale":1.0,"antiNoiseDb":-75.5,"lmsUpdateCount":2152000,"debugLmsMuMultiplier":1.6,"debugLatencyOverrideMs":150.0,"tier":"STANDARD","roughness":0.55,"personalRumbleBias":1.03,"rumbleAccelEma":0.78,"coarseLat":24.51,"coarseLon":121.452,"rumbleAuxPreviewFactor":1.0,"rumbleVibBoostApplied":1.06,"crowdsourcedPreloadBoost":1.0,"imuHybridMidErrImprove":1.0,"energyFactor":0.58,"stability":"OK","loopNum":6,"cycle":"C11"}'
