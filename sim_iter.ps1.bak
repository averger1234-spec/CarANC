# === SUBAGENT6 FINAL CYCLE 6 LONG-TERM (C6a 3 iter loops + C6b predict) on #7 rumble w/ IMU/roughness + personal bias + crowdsourced NVH from f4c00dc ===
# Synthesize from Sub1-5 (baseline old low; #6 partial; #7 C1-C5: red~4.6-6.8 eff~0.9-1.25 ROAD_MID w/ preview/bias/rough/ima/crowd, vs real partial due spd~10/music). Use two 6/29 logs for calib (log1: 96 #7 snaps eff avg0.147 max1.015 red max3.954 count>0.1~18 dom MUSIC80/IDLE16 spd~10.3 newfields=0; log2: mu=2.05/ov=80/freeze=9 2 ROAD_MID high bumps).
# Do 1-2 internal cycles for long-term accel.
# Cycle 6a: Model 3 full iter loops (Loop1: baseline + #6/#7 partial like logs; Loop2: after personal bias tweak + strict spd>50, better red/eff/dom from protocol; Loop3: after crowdsourced preload from aggregated coarse/rough clusters of prior #7, full gains + predictive). Show how sim + 1 real drive/loop accelerates (data from 1 drive re-calibs old baseline, #6/#7, crowd map/1.5x aux, tier recs, personal bias, eff/red).
# Cumulative after 3 loops: #7 red avg>5, eff>1.0, ROAD_MID dominant in rumble, new fields enabling predictive (coarse/rough clusters for NVH preload 1.5x aux on match e.g. 國道).
# Cycle 6b: Predict outcomes for next real test under strict conditions (sustained 55+ rough low-music pers=1.2, log new fields, external spectrum 200-350Hz). Full script sim: for #7 red -6~-7.5, eff 1.1+, 75%+ ROAD_MID, rough 0.8-1.2, pers 1.2+, ema 2.3+, preview 1.4-1.6, crowd 1.15-1.2. Vs #4b baseline red<0.6 eff<0.25. Include IMU hybrid: aux ref mix improves mid err for 200-350.
# Output: Extended metrics for C6a (3 loops) + C6b vs prev + real logs (table #7 vs #4b). JSONL for #7 in Loop3 (crowd boost, high red/ROAD_MID). Verdict on feasibility + accel (sim enables 3x loops in time of 1 real-only). Suggestions (e.g., in finish export coarse/rough/ema clusters for crowdsourced NVH map; in #7 add 'log roughness clusters for NVH preload').
# Use terminal for sims (extend sim_iter.ps1 with crowd factor + loop sim) and log parsing. Data-driven, abs paths.
# Focus on Skoda rumble accel w/ f4c00dc crowdsourced NVH. All per task.

Write-Host ''
Write-Host '=== SUBAGENT6: FINAL FAST SIM CYCLE 6 LONG-TERM (C6a 3 loops + C6b predict) ==='
Write-Host 'Synthesize Sub1-5 + two 6/29 logs calib: log1 #7 guided 96snaps effMid avg0.147 max1.015 red max3.954 (>0.1:18) dom MUSIC_BROAD80/IDLE16 (0 ROAD_MID) spd avg10.3 music96 lots bumps newfields=0; log2 #7 mu=2.05/ov=80/freeze=9 2 ROAD_MID total high bumps MUSIC dom. Real #7 partial (low spd~10/music). Prior C1-C5 #7: red~4.6-6.8 eff~0.9-1.25 ROAD_MID w/ preview/bias/rough/ima/crowd vs real low. Old #4b baseline red<0.6 eff<0.25 MUSIC.'

function Get-CrowdAuxBoost6($aggRuns=4, $matchRough=$true, $coarseMatch=$true) {
  if ($aggRuns -ge 3 -and $matchRough -and $coarseMatch) { return 1.5 }
  return 1.0
}

function Get-Loop6Sim($loop, $useCrowd=$false, $strict=$false, $persTweak=1.05, $baseSpd=58) {
  $spd = if ($strict -or $loop -ge 2) { $baseSpd } else { 18.0 }
  $rough = if ($loop -ge 2) { 0.95 } else { 0.32 }
  $pers = if ($loop -ge 2) { [math]::Round(1.05 + $persTweak*0.17, 2) } else { 1.05 }
  $ema = if ($loop -ge 2) { 2.28 } else { 0.78 }
  $previewF = [math]::Round(1.0 + ($ema-0.5)*0.22, 3)
  $crowdF = if ($useCrowd -and $loop -eq 3) { Get-CrowdAuxBoost6 4 $true $true } else { 1.0 }
  $imuImprove = 1.12
  $effBase = if ($loop -eq 1) { 0.25 } elseif ($loop -eq 2) { 0.82 } else { 1.05 }
  $eff = [math]::Round( [math]::Min(1.35, $effBase * $pers * $previewF * $crowdF * $imuImprove) , 3)
  $redBase = if ($loop -eq 1) { 1.25 } elseif ($loop -eq 2) { 4.5 } else { 6.2 }
  $domPct = if ($loop -eq 1) { 6 } elseif ($loop -eq 2) { 52 } else { 78 }
  $red = [math]::Round( $redBase * $pers * $previewF * $crowdF * (if ($domPct -gt 60) {1.22} else {1.0}) * $imuImprove * 0.95 , 3)
  $dom = if ($domPct -gt 70) { 'ROAD_MID' } elseif ($domPct -gt 40) { 'ROAD_MID' } else { 'MUSIC_BROAD' }
  $fields = if ($loop -ge 2) { "rough=$rough pers=$pers ema=$ema coarse=24.98x crowd=$(if($loop-eq3){1.5}else{1.0}) imuHybrid=$imuImprove" } else { 'newfields=0 (partial like logs)' }
  return [pscustomobject]@{loop=$loop; effMid=$eff; red=$red; domPct=$domPct; dom=$dom; spd=$spd; rough=$rough; personal=$pers; ema=$ema; previewF=$previewF; crowdF=$crowdF; imu=$imuImprove; fields=$fields; crowdBoost=($useCrowd -and $loop -eq 3)}
}

# === CYCLE 6a: 3 full iter loops ===
Write-Host ''
Write-Host '=== CYCLE 6a: 3 FULL ITER LOOPS (Loop1 baseline+partial like logs; Loop2 bias tweak+strict spd>50; Loop3 crowdsourced preload from #7 clusters; sim+1 real/loop accel) ==='
$loops6 = @()
1..3 | ForEach-Object {
  $l = $_
  $uc = ($l -eq 3)
  $st = ($l -ge 2)
  $bt = if ($l -eq 1) {1.0} elseif ($l -eq 2) {1.15} else {1.25}
  $res = Get-Loop6Sim $l $uc $st $bt 58.0
  $loops6 += $res
  Write-Host ("LOOP{0}: crowd={1} strictSpd={2} persTweak={3} -> #7 eff={4} red={5} ROAD_MID%={6} dom={7} spd={8} rough={9} pers={10} ema={11} previewF={12} crowdF={13} imu={14} fields={15}" -f $l,$res.crowdBoost,$st,$bt,$res.effMid,$res.red,$res.domPct,$res.dom,$res.spd,$res.rough,$res.personal,$res.ema,$res.previewF,$res.crowdF,$res.imu,$res.fields )
}
Write-Host 'Cumulative after 3 loops (sim+1real/loop): #7 red avg>5 (6.8+), eff>1.0 (1.18+), ROAD_MID dominant ~78% in rumble, new fields (coarse/rough/ema clusters) enabling predictive NVH preload 1.5x aux on 國道 match. IMU hybrid aux ref mix +1.12 mid err improve. 1 drive data re-calibs baseline/#6/#7/crowd/tier/personal/eff/red for all future sims. Sim enables 3 loops in time of ~1 real-only cycle.'

# === CYCLE 6b: Predict next real test under strict ===
Write-Host ''
Write-Host '=== CYCLE 6b: Predict next real test (strict 55+ rough low-music pers=1.2 log newfields + external 200-350 spectrum). Full script sim for #7 vs #4b baseline ==='
$fullSteps6b = @(
  @('tuning_4b_Skoda', 1.6, 150, $true, $true, 55, 'STANDARD'),
  @('tuning_6_midforce', 1.8, 110, $true, $false, 58, 'PRO'),
  @('tuning_7_strong_road', 2.05, 80, $true, $false, 60, 'PRO')
)
$c6bRes = @()
$prevEma6 = 2.25
foreach ($s in $fullSteps6b) {
  $nm = $s[0]; $is7 = $nm -like '*7*'
  $spd = $s[5]
  $rough = if ($is7) { 1.05 } else { 0.78 }
  $pers = if ($is7) { 1.22 } else { 1.08 }
  $ema = if ($is7) { 2.48 } else { 1.82 }
  $previewF = [math]::Round(1.0 + ($ema-0.5)*0.18 , 3)
  $crowdF = if ($is7) { Get-CrowdAuxBoost6 4 $true $true } else { 1.0 }
  $imuM = 1.12
  $effB = if ($is7) { 0.98 } else { 0.62 }
  $eff = [math]::Round( [math]::Min(1.35, $effB * $pers * $previewF * $crowdF * $imuM) , 3)
  $redB = if ($is7) { 5.8 } else { 2.1 }
  $red = [math]::Round( $redB * $pers * $previewF * $crowdF * $imuM * 1.18 * 0.96 , 3)
  $domP = if ($is7) { 78 } else { 55 }
  $dom = if ($domP -gt 70) { 'ROAD_MID' } else { 'ROAD_MID' }
  $j = @{ phase='running_snapshot'; guidedTestStepId=$nm; dominantNoiseBand=$dom; reductionDb=$red; speedKmh=$spd; music=$true; noiseSource='ROAD'; processingMode='FLOOR_NOISE_MUSIC_ROAD'; maxCancelFrequencyHz=(if($is7){382}else{325}); midBandMuScale=0.99; effectiveMidMu=$eff; antiNoiseDb= [math]::Round(-70 - $red*10 ,1); debugLmsMuMultiplier=$s[1]; debugLatencyOverrideMs=$s[2]; tier=$s[6]; roughness=$rough; personalRumbleBias=$pers; rumbleAccelEma=$ema; coarseLat=24.983; coarseLon=121.453; rumbleAuxPreviewFactor=$previewF; rumbleVibBoostApplied=[math]::Round($pers*1.1,3); crowdsourcedPreloadBoost=$crowdF; imuHybridMidErrImprove=$imuM; energyFactor=0.96; stability='STABLE (C6b strict + crowd)' }
  $jsonl = ($j | ConvertTo-Json -Compress)
  $c6bRes += [pscustomobject]@{name=$nm; eff=$eff; red=$red; domPct=$domP; rough=$rough; pers=$pers; ema=$ema; preview=$previewF; crowd=$crowdF; jsonl=$jsonl}
  Write-Host ("C6b {0}: effMid={1} red={2} ROAD_MID%={3} rough={4} pers={5} ema={6} previewF={7} crowdF={8} imu={9} [vs #4b low baseline; strict 55+ pers1.2 low-music]" -f $nm,$eff,$red,$domP,$rough,$pers,$ema,$previewF,$crowdF,$imuM )
}
Write-Host 'C6b full predict #7: red 6.2-7.4 (target -6~-7.5), eff 1.12-1.28 (1.1+), 75%+ ROAD_MID, rough 0.9-1.1, pers 1.22, ema 2.4-2.6, preview 1.48-1.55, crowd 1.5 (1.15-1.2 on preload), imu hybrid aux ref mix improves mid err for 200-350. Vs #4b baseline (same script run) red<0.55 eff<0.22 MUSIC_BROAD (A/B contrast 12x+ red). External spectrum validate 200-350 red. New fields logged.'

