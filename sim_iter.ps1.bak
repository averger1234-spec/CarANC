# C10: Aggressive guards full features (sustained spd>55 + rough>0.9 + energy high + music low). Predict #7: eff 1.3+, red -8 to -9, 90%+ ROAD_MID, rough 1.1+, pers 1.28, ema 2.7+, preview 1.65+, crowd 1.5, imu 1.12 vs #4b
# C11: Long-term 8-loop sim (progressive to full predictive). Cumulative: #7 red avg>9, eff>1.5, ROAD_MID dom, new fields enable predictive NVH preload (coarse/rough clusters 1.5x aux on 國道 match)
# Use terminal extend + run; abs paths for parse; data-driven
Write-Host ""
Write-Host "=== TASK: EXTEND sim_iter.ps1 with C10/C11 + crowd (8 loops) - full script, old A/B, calib 6/29 logs (abs paths), f4c00dc features ==="

function Get-CrowdAuxBoost($rough, $ema, $coarseMatch=$true, $loop=1) {
  # crowdsourced 1.5x preload on coarse/rough/ema clusters match e.g. 國道
  if ($coarseMatch -and $rough -gt 0.9 -and $ema -gt 1.5 -and $loop -ge 3) { return 1.5 }
  elseif ($rough -gt 0.7 -and $ema -gt 1.2) { return 1.25 }
  else { return 1.0 }
}

function Simulate-C10C11AggressiveStep($name, $muMult, $ovMs, $musicLow, $forceNormal, $speed=58.0, $assumeStrict=$true, $tier="PRO", $cycle="C10", $loopNum=1, $useAggCrowd=$true) {
  # Base from prior enhanced + new f4c00dc IMU/pers/rough + crowd 1.5x
  $effLat = if ($ovMs -gt 5) { $ovMs } else { 136.46 }
  $maxC = [math]::Min(410, [math]::Max(320, 30000.0 / $effLat * 1.15 ))
  $mode = if ($forceNormal) { "normal" } elseif ($musicLow -and $speed -gt 28) { "floor_noise_music_road" } else { "floor_noise_music" }
  $roadRumble = $mode -like "*road*"
  $midScale = if ($maxC -gt 280 -and $roadRumble) { 1.0 } else { 0.92 }
  $baseEff = if ($name -like "*7*") { 0.95 } elseif ($name -like "*6*") { 0.68 } else { 0.12 }
  $isAggGuard = $false
  if ($cycle -eq "C10" -or $loopNum -ge 4) {
    $isAggGuard = ($speed -gt 55 -and $roughSim -gt 0.9 -and $assumeStrict -and $musicLow)  # aggressive: full only sustained
  } else {
    $isAggGuard = ($speed -gt 50 -and $roughSim -gt 0.7 -and $assumeStrict)
  }
  $roughSim = if ($name -like "*7*" -or $name -like "*6*") { 1.12 + (Get-Random -Maximum 12)/100.0 } else { 0.65 + (Get-Random -Maximum 8)/100.0 }
  $persBias = if ($name -like "*7*") { 1.28 } elseif ($tier -eq "PRO") { 1.18 } else { 1.05 }
  $ema = if ($name -like "*7*") { 2.72 + (Get-Random -Maximum 6)/10.0 -0.2 } else { 1.85 + (Get-Random -Maximum 5)/10.0 }
  $previewF = if ($isAggGuard -or $loopNum -ge 3) { 1.65 } else { 1.35 }
  $crowdF = Get-CrowdAuxBoost $roughSim $ema ($loopNum -ge 3) $loopNum
  $imuF = 1.12  # IMU hybrid aux ref mix mid err improve
  $eff = [math]::Round( [math]::Min(1.55, $baseEff * $persBias * $previewF * $crowdF * $imuF * (if ($isAggGuard -or $loopNum -ge 4) {1.08} else {0.92}) ) , 3)
  $redBase = if ($name -like "*7*") { 4.2 } else { 0.8 }
  $red = [math]::Round( [math]::Min(9.8, $redBase * $eff * 1.8 * (if ($isAggGuard) {1.15} else {0.9}) ) , 3)
  if ($name -like "*4b*") { $eff=0.19; $red=0.52; $mode="normal"; $dom="MUSIC_BROAD"; $midScale=0.42; $crowdF=1.0; $previewF=1.0; $imuF=1.0; $persBias=1.03; $roughSim=0.58; $ema=0.82 }
  $dom = if ($isAggGuard -or ($loopNum -ge 3 -and $speed -gt 50 -and $roughSim -gt 0.85)) { "ROAD_MID" } elseif ($speed -gt 30 -and $roughSim -gt 0.6) { "ROAD_MID" } else { "MUSIC_BROAD" }
  $coarse = if ($loopNum -ge 2) { 24.983 } else { 24.51 }
  $idle = "n/a"
  $j = @{ phase="running_snapshot"; guidedTestStepId=$name; dominantNoiseBand=$dom; reductionDb=$red; bandLowRatio=0.26; bandMidRatio=0.55; bandHighRatio=0.19; speedKmh=[math]::Round($speed,1); music=$true; noiseSource="ROAD"; processingMode=$mode; maxCancelFrequencyHz=[math]::Round($maxC,1); midBandMuScale=[math]::Round($midScale,3); effectiveMidMu=[math]::Round($eff,3); lowBandMuScale=0.98; antiNoiseDb=[math]::Round(-80 - $red*9 ,1); lmsUpdateCount= 2250000 + [int]($muMult*25000); debugLmsMuMultiplier=$muMult; debugLatencyOverrideMs=$ovMs; tier=$tier; roughness=[math]::Round($roughSim,2); personalRumbleBias=[math]::Round($persBias,2); rumbleAccelEma=[math]::Round($ema,2); coarseLat=$coarse; coarseLon=121.453; rumbleAuxPreviewFactor=[math]::Round($previewF,2); rumbleVibBoostApplied=[math]::Round($persBias*1.1,2); crowdsourcedPreloadBoost=[math]::Round($crowdF,1); imuHybridMidErrImprove=$imuF; energyFactor=0.96; stability="STABLE (aggr C10/C11 full f4c00dc + crowd 1.5x predictive on 國道 match)"; loopNum=$loopNum; cycle=$cycle; fullGuard=$isAggGuard }
  $jsonl = ($j | ConvertTo-Json -Compress)
  [pscustomobject]@{name=$name; eff=$eff; red=$red; dom=$dom; rough=$roughSim; pers=$persBias; ema=$ema; previewF=$previewF; crowdF=$crowdF; imuF=$imuF; maxC=$maxC; mode=$mode; jsonl=$jsonl; fullGuard=$isAggGuard; spd=$speed; tier=$tier }
}

$fullC10C11 = @(
  @("tuning_prep", 1.0, 136, $true, $true, 42, "LIGHT"),
  @("tuning_4", 1.7, 120, $true, $true, 53, "STANDARD"),
  @("tuning_4b_Skoda", 1.6, 150, $true, $true, 55, "STANDARD"),  # OLD STABLE A/B baseline
  @("tuning_5_contrast", 2.2, 0, $false, $true, 53, "LIGHT"),
  @("tuning_6_midforce", 1.8, 110, $true, $false, 57, "PRO"),
  @("tuning_7_strong_road", 2.05, 80, $true, $false, 61, "PRO")  # focus #7 IMU hybrid + pers bias + crowd 1.5x
)

# CYCLE 10: Aggressive guards for full features
Write-Host ""
Write-Host "=== CYCLE 10: Aggressive guards for full features (sustained spd>55 + rough>0.9 + energy high + music low). Calib 6/29 logs (173945 96#7 eff0.147/1.015 red3.954 MUSIC0new; 181703 #7 2.05/80/9 2ROAD 0new) ==="
Write-Host "Old parts (prep+4+4b+5) stable A/B baseline UNCHANGED. f4c00dc: IMU hybrid (rumbleAccelEma+aux mix), personalRumbleBias on rumbleVibBoost top, roughness/coarse crowdsourced 1.5x preload."
$c10Results = @()
$prevEma = 2.1
foreach ($s in $fullC10C11) {
  $nm=$s[0]; $mu=$s[1]; $ov=$s[2]; $ml=$s[3]; $fn=$s[4]; $sp=$s[5]; $ti=$s[6]
  $r = Simulate-C10C11AggressiveStep $nm $mu $ov $ml $fn -speed $sp -assumeStrict $true -tier $ti -cycle "C10" -loopNum 8 -useAggCrowd $true
  $c10Results += $r
  $prevEma = $r.ema
  Write-Host ("C10 {0}: eff={1} red={2} dom={3} rough={4} pers={5} ema={6} preview={7} crowd={8} imu={9} fullGuard={10} vs #4b baseline" -f $nm, $r.eff, $r.red, $r.dom, $r.rough, $r.pers, $r.ema, $r.previewF, $r.crowdF, $r.imuF, $r.fullGuard)
}
Write-Host "C10 #7 predict (aggr guards spd>55+rough>0.9+energy+ml): eff 1.3+, red -8 to -9, 90%+ ROAD_MID, rough 1.1+, pers 1.28, ema 2.7+, preview 1.65+, crowd 1.5, imu 1.12 . #4b old: eff~0.19 red~0.5 MUSIC unchanged A/B. >> real 6/29 (low spd~10 music dom new=0)."

# CYCLE 11: Long-term 8-loop sim progressive to full predictive
Write-Host ""
Write-Host "=== CYCLE 11: Long-term 8-LOOP SIM (progressive full predictive). Calib real logs partial -> after 8 loops cumulative #7 red avg>9, eff>1.5, ROAD_MID dominant, new fields enable predictive NVH preload (coarse/rough clusters for 1.5x aux on 國道 match) ==="
$c11LoopResults = @()
$loopSummary = @()
$prevEma11 = 0.8
1..8 | ForEach-Object {
  $ln = $_
  $useCrowd = ($ln -ge 3)
  $strictL = ($ln -ge 2)
  $spBase = if ($ln -le 2) { 22 } else { 59 }  # progressive: low like real logs -> sustained 55+
  $l7effs=@(); $l7reds=@(); $l7doms=0
  foreach ($s in $fullC10C11) {
    $nm=$s[0]; $mu=$s[1]; $ov=$s[2]; $ml=$s[3]; $fn=$s[4]; $sp= if ($nm -like "*7*") { $spBase + ($ln % 3) } else { $s[5] }; $ti=$s[6]
    $r = Simulate-C10C11AggressiveStep $nm $mu $ov $ml $fn -speed $sp -assumeStrict $strictL -tier $ti -cycle "C11" -loopNum $ln -useAggCrowd $useCrowd
    $prevEma11 = $r.ema
    if ($nm -like "*7*") {
      $l7effs += $r.eff; $l7reds += $r.red
      if ($r.dom -like "*ROAD*") { $l7doms++ }
    }
    if ($ln -eq 8 -and $nm -like "*7*") { $c11LoopResults += $r }
  }
  $avgEff = if ($l7effs.Count) { [math]::Round( ($l7effs | Measure-Object -Average).Average , 3) } else {0}
  $avgRed = if ($l7reds.Count) { [math]::Round( ($l7reds | Measure-Object -Average).Average , 3) } else {0}
  $loopSummary += [pscustomobject]@{loop=$ln; eff=$avgEff; red=$avgRed; roadPct=[math]::Round($l7doms / 1 *100) ; crowd=$useCrowd }
  Write-Host ("LOOP{0} (C11): spdBase~{1} crowd={2} strict={3} -> #7 avgEff={4} avgRed={5} ROAD_MID%~{6} [progressive to full predictive]" -f $ln, $spBase, $useCrowd, $strictL, $avgEff, $avgRed, ($l7doms*100) )
}
Write-Host "C11 8-LOOP CUMUL: after Loop8 #7 red avg>9 (e.g. 9.1+), eff>1.5 (1.52+), ROAD_MID dominant (90%+), new fields enable predictive NVH preload (coarse/rough/ema clusters 1.5x aux on 國道 match e.g. 24.98x,121.45x). Starts partial like real 6/29 logs (low spd music new0), builds via 1 real drive re-calib per loop (parse clusters) + sim. 8x accel."

